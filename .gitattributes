# Auto detect text files and perform LF normalization
* text=auto

# Audio files — treat as binary to prevent line-ending corruption
*.mp3 binary
*.mp4 binary
*.mov binary
*.avi binary
*.mkv binary
*.jpg binary
*.jpeg binary
*.png binary
*.webp binary
*.wav binary
*.ogg binary
*.m4a binary
*.aac binary
*.flac binary
